# Default Tilt cluster mode for ms02 systemd app units.
# Override per-user: copy to ~/.config/microscaler/tilt-cluster.env
#   TILT_K8S_CLUSTER=kind
# and add a systemd drop-in if needed.

TILT_K8S_CLUSTER=shared-k8s
KUBECONFIG=/home/casibbald/Workspace/microscaler/shared-gitops-k8s-cluster/kubeconfig/shared-k8s.yaml
TILT_USE_SHARED_KIND_INFRA=1
