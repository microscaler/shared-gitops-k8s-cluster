# Shared k3s cluster constants (ms02 Multipass layout).
# Loaded by just (`set dotenv-load`) and sourced by bash recipes.

K8S_CLUSTER_NAME=shared-k8s
K8S_CONTEXT=shared-k8s

# Multipass guests (1 control plane + 3 workers).
K8S_CP=k8s-cp-1
# Workers (comma-separated — dotenv cannot hold space-separated lists).
K8S_WORKERS=k8s-worker-1,k8s-worker-2,k8s-worker-3

# Static IPs on mpqemubr0 (10.177.76.0/24). Gateway is Multipass host (10.177.76.1).
K8S_CP_IP=10.177.76.137
K8S_WORKER_1_IP=10.177.76.211
K8S_WORKER_2_IP=10.177.76.212
K8S_WORKER_3_IP=10.177.76.213

# MetalLB L2 pool (same L2 as Multipass bridge).
METALLB_POOL_START=10.177.76.220
METALLB_POOL_END=10.177.76.239

# In-cluster registry LoadBalancer (fixed IP in pool).
REGISTRY_LB_IP=10.177.76.220
REGISTRY_PORT=5000

# Backward compat with Kind-era Tilt tags (localhost:5001 → cluster registry).
REGISTRY_HOST_ALIAS=localhost:5001

# ms02 workspace bind-mount into workers (cylon-daemon hostPath).
WORKSPACE_HOST=/home/casibbald/Workspace/microscaler
WORKSPACE_GUEST=/home/casibbald/Workspace/microscaler

# VM sizing
K8S_CP_CPUS=2
K8S_CP_MEM=4G
K8S_CP_DISK=30G
K8S_WORKER_CPUS=4
K8S_WORKER_MEM=8G
K8S_WORKER_DISK=40G
